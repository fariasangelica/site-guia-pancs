NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_PASSWORD=defina-uma-senha-forte-aqui

# Envio de e-mail das submissoes de especies (Resend - https://resend.com)
# 1. Crie uma conta gratuita no Resend e gere uma API key.
# 2. Cole a chave aqui (e tambem nas Environment Variables do projeto no Vercel).
RESEND_API_KEY=

# Remetente do e-mail. Em testes pode usar onboarding@resend.dev,
# mas nesse modo o Resend so entrega para o e-mail dono da conta.
# Em producao, verifique um dominio no Resend e use algo como: contato@seudominio.com
EMAIL_FROM=onboarding@resend.dev

# E-mail da conta Resend (modo teste). Opcional; padrao: primeiro e-mail da curadoria.
RESEND_ACCOUNT_EMAIL=angelicafarioliveira@gmail.com
